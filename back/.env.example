# =============================================================================
# Backend — copia este archivo a `.env` y rellena los valores.
#   cp .env.example .env
# No subas `.env` a Git (contiene secretos).
# =============================================================================

# Puerto HTTP del API (front en dev suele apuntar a http://localhost:4000/api)
PORT=4000

# development | production
NODE_ENV=development

# MySQL — Prisma y el servidor leen esta URL.
# Local con docker-compose en la raíz del repo (puerto host 3307):
#   docker compose up -d
# Sustituye USUARIO, CONTRASEÑA y nombre de base según tu MySQL / docker-compose.yml
DATABASE_URL="mysql://USUARIO:CONTRASEÑA@127.0.0.1:3307/fersua_dashboard"

# Secreto para firmar JWT (login). Genera uno largo y aleatorio en producción.
# Ejemplo: openssl rand -base64 48
JWT_SECRET=cambia_esto_por_un_secreto_largo

# Contraseña para limpiar datos importados desde la UI (Importaciones → zona peligrosa).
# Solo rol ADMIN. Debe coincidir EXACTAMENTE con lo que escribes en el campo de la pantalla.
# Endpoints: POST /api/import/wipe-imported-tables y POST /api/import/wipe-cpa
# Si está vacío o no existe, la limpieza queda deshabilitada.
IMPORT_WIPE_SECRET=elige_una_clave_solo_para_limpieza
