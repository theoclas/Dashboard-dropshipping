# =============================================================================
# Frontend (Vite) — copia este archivo a `.env` y ajusta si hace falta.
#   cp .env.example .env
# Variables deben empezar por VITE_ para exponerse al build.
# No subas `.env` a Git.
# =============================================================================

# URL base del API (incluye /api al final).
# Desarrollo local (backend en PORT=4000):
VITE_API_URL=http://localhost:4000/api

# Producción (ejemplo — sustituye por tu dominio):
# VITE_API_URL=https://tu-dominio.com/api
